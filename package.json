    "tabby-plugin",
    "claude",
    "claude-code",
    "tab-title"
  ],
  "main": "dist/index.js",
  "typings": "dist/index.d.ts",
  "scripts": {
    "build": "webpack --progress --color",
    "watch": "webpack --progress --color --watch",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/windeko/tabby-claude-title.git"
  },
  "author": "Vladimir Traigel <vladimir@arbio.com>",
  "license": "MIT",
  "devDependencies": {
    "@angular/common": "^9.1.9",
    "@angular/core": "^9.1.9",
    "@types/node": "^18.0.0",
    "rxjs": "^6.6.0",
    "tabby-core": "^1.0.163",
    "tabby-terminal": "^1.0.163",
    "ts-loader": "^9.4.0",
    "typescript": "^4.7.4",
    "webpack": "^5.74.0",
    "webpack-cli": "^4.10.0"
  }
}
